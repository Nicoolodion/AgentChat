# NanoGPT
NANOGPT_API_KEY=
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

NEURALWATT_API_KEY=
NEURALWATT_BASE_URL=https://api.neuralwatt.com/v1


DEFAULT_MODEL=moonshotai/kimi-k2.6:thinking
TITLE_MODEL=Qwen/Qwen3.6-35B-A3B

AGENT_VISION_MODEL=kimi-k2.7-code
AGENT_VISION_FALLBACK_MODEL=kimi-k2.6

# Database (SQLite for production — relative to container root; mapped to ./prisma on host)
DATABASE_URL=file:/app/prisma/chatinterface.db

SEARXNG_URL=http://searxng:8080

# Auth and registration toggles
AUTH_REQUIRED=true
REGISTRATION_ENABLED=true
COOKIE_NAME=chatinterface_session
SESSION_TTL_HOURS=168

# Encryption keys — generate strong 32-byte keys with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production. The defaults below are dev-only placeholders.
APP_ENCRYPTION_KEY=REPLACE_ME_WITH_32_BYTE_BASE64_KEY
SESSION_ENCRYPTION_KEY=REPLACE_ME_WITH_32_BYTE_BASE64_KEY

# Local mode user (used only when AUTH_REQUIRED=false)
GUEST_USERNAME=local-user

# Simple abuse protection
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=25

# File storage root (per-user subfolders are created automatically)
DATA_DIR=data

# Agent configuration
AGENT_ENABLED=true
AGENT_SANDBOX_URL=http://agent-sandbox:8080
AGENT_MAX_TOOL_CALLS=50
AGENT_WORKSPACE_DIR=data/agent-workspaces
AGENT_IMAGE_ANALYZE_MAX_BATCH=15
AGENT_IMAGE_ANALYZE_MAX_CONCURRENCY=2

# Production-only overrides
NODE_ENV=production
COOKIE_SECURE=true  # ensures the session cookie is set with the Secure flag

# ── Deploy webhook ───────────────────────────────────────────────────────────
# Required for the deploy-webhook container. HOST_DEPLOY_PATH must be the
# absolute path on the Unraid host that contains docker-compose.yml (the place
# you `git pull`). WEBHOOK_SECRET is a random string shared with GitHub Actions.
HOST_DEPLOY_PATH=/mnt/user/appdata/AgentChat
WEBHOOK_SECRET=   # generate with:  openssl rand -hex 32

# ── Mobile Task Launcher / Email-reply feature ───────────────────────────────
# All optional. Unset MAIL_SMTP_HOST -> skip email; unset NTFY_BASE_URL ->
# skip push; either alone still works.
PUBLIC_BASE_URL=https://chat.nicoolodion.com

# Outbound mail (SMTP)
MAIL_FROM=agent@nicoolodion.com
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASS=

# Inbound mail (IMAP poller) — disable with MAIL_INBOUND_ENABLED=false
MAIL_INBOUND_ENABLED=true
MAIL_INBOX_HOST=
MAIL_INBOX_PORT=993
MAIL_INBOX_USER=agent@nicoolodion.com
MAIL_INBOX_PASS=
MAIL_INBOX_POLL_SECONDS=30

# Push (self-hosted ntfy / UnifiedPush).
NTFY_BASE_URL=https://ntfy.nicoolodion.com
NTFY_DEFAULT_AUTH=

